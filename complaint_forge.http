### Health check
GET {{baseUrl}}/health


### A2A specialist health check
GET {{a2aBaseUrl}}/health


### A2A specialist agent card
GET {{a2aBaseUrl}}/.well-known/agent-card.json


### A2A refund specialist review
POST {{a2aBaseUrl}}/tasks/refund-specialist
Content-Type: application/json
Authorization: Bearer {{a2aToken}}

{
  "complaint": "My order #ORD-55555 was a $950 espresso machine that arrived badly damaged. I have already contacted support twice, I am very angry, and I want a full refund immediately.",
  "triage": {
    "is_complaint": true,
    "confidence": 0.98,
    "reason": "Customer reports damaged high-value order and requests refund.",
    "customer_email": "ada@example.com",
    "order_id": "ORD-55555"
  },
  "customer_email": "ada@example.com",
  "order_id": "ORD-55555",
  "customer_history": {
    "source": "salesforce",
    "account_name": "Ada Lovelace",
    "email": "ada@example.com",
    "order_id": "ORD-55555",
    "matched_order": {
      "Id": "801xx0000000001AAA",
      "OrderNumber": "ORD-55555",
      "Status": "Activated",
      "TotalAmount": 950
    },
    "recent_cases": [
      {
        "CaseNumber": "00012345",
        "Subject": "Damaged delivery",
        "Status": "Closed",
        "Priority": "High"
      }
    ],
    "has_prior_cases": true,
    "has_prior_return_orders": false
  },
  "analysis": {
    "issue_type": "product",
    "sentiment": "very_negative",
    "urgency": "high",
    "repeat_complaint": true,
    "key_details": "High-value damaged order with repeat contact and full refund request."
  },
  "resolution": {
    "resolution_type": "escalate",
    "refund_amount": 0,
    "credit_amount": 0,
    "action_needed": "Refund amount exceeds $500 approval limit",
    "confidence": 0
  },
  "policy_result": {
    "approved": false,
    "reasons": [
      "Refund amount exceeds $500 approval limit"
    ]
  },
  "eval_results": {},
  "actions_taken": [
    {
      "action": "policy_escalation",
      "reason": "Refund amount exceeds $500 approval limit"
    }
  ]
}


### Zendesk complaint webhook - accepted and processed in background
POST {{baseUrl}}/webhook/zendesk/complaint
Content-Type: application/json

{
  "ticket": {
    "id": 12345,
    "subject": "Order never arrived",
    "description": "My order #ORD-98765 never arrived. I am extremely upset and want a refund. Email: ada@gmail.com",
    "requester": {
      "email": "ada@example.com"
    }
  }
}


### Test complaint endpoint - runs synchronously and returns completed/pending result
POST {{baseUrl}}/test/complaint
Content-Type: application/json

{
  "email": "ada@example.com",
  "complaint": "My order #ORD-98765 never arrived. I am extremely upset and want a refund."
}


### Test complaint endpoint - high-value refund should escalate to human review
POST {{baseUrl}}/test/complaint
Content-Type: application/json

{
  "email": "ada@example.com",
  "complaint": "My order #ORD-55555 was a $950 espresso machine that arrived badly damaged. I have already contacted support twice, I am very angry, and I want a full refund immediately."
}


### Non-complaint ticket - triage should ignore
POST {{baseUrl}}/test/complaint
Content-Type: application/json

{
  "email": "ada@example.com",
  "complaint": "Thanks for the update. No problem from my side."
}


### List pending human reviews
GET {{baseUrl}}/review


### Get a specific pending human review
GET {{baseUrl}}/review/{{threadId}}


### Resume human review
POST {{baseUrl}}/review/{{threadId}}/resume
Content-Type: application/json

{
  "approved": true,
  "notes": "Reviewed and approved by support lead.",
  "final_response": "Thanks for contacting us. Our support team reviewed your case and will follow up directly with the next steps."
}


### Resume human review with adjusted resolution
POST {{baseUrl}}/review/{{threadId}}/resume
Content-Type: application/json

{
  "approved": true,
  "notes": "Approved partial refund after reviewing Salesforce history and specialist recommendation.",
  "resolution": {
    "resolution_type": "partial_refund",
    "refund_amount": 75,
    "credit_amount": 0,
    "action_needed": "Create refund workflow case in Salesforce",
    "confidence": 0.95
  },
  "final_response": "Thanks for your patience. We reviewed your case and approved a partial refund. Our support team will follow up with confirmation shortly."
}
