AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-client-id
SALESFORCE_CLIENT_SECRET=your-connected-app-client-secret
SALESFORCE_API_VERSION=v61.0
SALESFORCE_RETURN_ORDER_OBJECT=ReturnOrder
SALESFORCE_RETURN_ORDER_ACCOUNT_FIELD=AccountId
SALESFORCE_RETURN_ORDER_ORDER_FIELD=OrderId

LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT="complaint-forge"

ZENDESK_TICKET_COMPLETION_STATUS=solved
ZENDESK_MCP_URL=https://mcp.mcpbundles.com/bundle/zendesk
ZENDESK_MCP_AUTH_TOKEN=optional-bearer-token
ZENDESK_MCP_UPDATE_TICKET_TOOL=Zendesk Upsert Ticket

A2A_SPECIALIST_URL=http://localhost:8010
A2A_SPECIALIST_AUTH_TOKEN=optional-bearer-token

# Mailchimp Transactional API settings (email and SMS) - uses official SDK
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_FROM_EMAIL=your-sender@example.com
MAILCHIMP_TIMEOUT=30

# OpenTelemetry — works with any OTLP backend (New Relic, Jaeger, Honeycomb, Grafana, etc.)
# New Relic: endpoint = https://otlp.nr-data.net  (EU: https://otlp.eu01.nr-data.net)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.nr-data.net
OTEL_EXPORTER_OTLP_HEADERS=api-key=your-new-relic-license-key

# Set OUTBOUND_COMMUNICATION_ENABLED=false to disable all email/SMS sending
OUTBOUND_COMMUNICATION_ENABLED=true
